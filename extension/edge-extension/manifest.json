{
  "manifest_version": 3,
  "name": "Enterprise Web Test Platform Helper",
  "version": "0.1.0",
  "description": "Phase 3 lightweight Edge assistant entry for current page summary and runtime status.",
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "Web Test Helper",
    "default_popup": "popup.html"
  },
  "permissions": ["activeTab", "tabs", "storage", "nativeMessaging"],
  "host_permissions": ["<all_urls>"],
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content-script.js"],
      "run_at": "document_idle"
    }
  ]
}
